# ---- x402 (seller side) ----
# EVM address on Base that receives USDC for paid calls.
X402_RECEIVING_ADDRESS=0x0000000000000000000000000000000000000000
# Coinbase public facilitator. Use the mainnet URL in prod, testnet for dev.
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=base

# ---- SMM panel upstreams ----
# Comma-separated priority list. First entry is primary.
SMM_UPSTREAMS=jap,peakerr
SMM_JAP_URL=https://justanotherpanel.com/api/v2
SMM_JAP_KEY=
SMM_PEAKERR_URL=https://peakerr.com/api/v2
SMM_PEAKERR_KEY=

# ---- UGC creator marketplace ----
# Billo is primary; Insense is fallback. If BILLO_API_KEY is unset, UGC routes to Insense.
UGC_PRIMARY=billo
BILLO_API_URL=https://api.billo.app/v1
BILLO_API_KEY=
INSENSE_API_URL=https://api.insense.pro/v1
INSENSE_API_KEY=

# ---- Storage (Neon Postgres via Vercel Marketplace) ----
# DATABASE_URL is injected by the Vercel Marketplace Neon integration in prod.
DATABASE_URL=postgres://user:pass@localhost:5432/aeo_engine

# ---- Dev toggles ----
# 1 = bypass real providers and use FakeProvider. Useful for local end-to-end tests.
USE_FAKE_PROVIDERS=0
# 1 = bypass x402 middleware verification (dev only).
BYPASS_X402=0
